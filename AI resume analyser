# -------------------------
# ROUTES
# -------------------------

@app.route("/",methods=["GET","POST"])
def index():

    issues=[]
    suggestions=[]
    score=0
    analyzed=False

    if request.method=="POST":

        code=request.form["code"]

        issues,suggestions,score=analyze_code(code)

        analyzed=True

    return render_template_string(
        page,
        issues=issues,
        suggestions=suggestions,
        score=score,
        analyzed=analyzed
    )


