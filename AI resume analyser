
from flask import Flask,request,render_template_string
import ast

app = Flask(__name__)

# -------------------------
# CODE ANALYSIS ENGINE
# -------------------------

def analyze_code(code):

    issues = []
    suggestions = []
    score = 100

    try:
        tree = ast.parse(code)
    except:
        issues.append("Syntax Error detected")
        score -= 40
        return issues,suggestions,score

    for node in ast.walk(tree):

        # Detect global variables
        if isinstance(node,ast.Global):
            issues.append("Global variable usage detected")
            score -= 5

        # Detect long functions
        if isinstance(node,ast.FunctionDef):
            if len(node.body) > 20:
                issues.append(f"Function '{node.name}' is too long")
                score -= 10

        # Detect empty except blocks
        if isinstance(node,ast.ExceptHandler):
            if len(node.body)==1 and isinstance(node.body[0],ast.Pass):
                issues.append("Empty exception handler found")
                score -= 15

    # Suggestions
    if "for" in code and "range(len(" in code:
        suggestions.append("Consider using enumerate() instead of range(len())")

    if "==" in code and "None" in code:
        suggestions.append("Use 'is None' instead of '== None'")

    if "print(" in code:
        suggestions.append("Use logging instead of print in production")

    score = max(score,0)

    return issues,suggestions,score


